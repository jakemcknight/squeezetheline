ODDS_API_KEY = "your-odds-api-key-here"

# Supabase auth (https://supabase.com — free tier)
SUPABASE_URL = "https://YOURPROJECT.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"
# Service-role key (needed so the app can write auto-picks to Supabase)
# Find it in Supabase: Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key-here"

# Comma-separated list of emails granted admin access (refresh data, line shopping, etc.)
ADMIN_EMAILS = "you@example.com"
