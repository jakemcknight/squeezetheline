ODDS_API_KEY = "your-odds-api-key-here"

# Supabase auth (https://supabase.com — free tier)
SUPABASE_URL = "https://YOURPROJECT.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"
# Service-role key (needed so the app can write auto-picks to Supabase)
# Find it in Supabase: Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key-here"

# Comma-separated list of emails granted admin access (refresh data, line shopping, etc.)
ADMIN_EMAILS = "you@example.com"

# Anthropic API key for the admin-only 'AI Analysis' tab
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY = "sk-ant-..."

# Secret token for the automated refresh webhook.
# A free cron service pings your app URL with this token to trigger the
# daily refresh/grade pipeline without needing a user to log in.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REFRESH_TOKEN = "your-random-secret-token"

# Optional: post daily digest summaries to a Discord channel
# Create a webhook in your server: Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL = ""
