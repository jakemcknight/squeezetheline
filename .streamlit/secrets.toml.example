ODDS_API_KEY = "your-odds-api-key-here"

# Supabase auth (https://supabase.com — free tier)
SUPABASE_URL = "https://YOURPROJECT.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"
# Service-role key (needed so the app can write auto-picks to Supabase)
# Find it in Supabase: Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key-here"

# Comma-separated list of emails granted admin access (refresh data, line shopping, etc.)
ADMIN_EMAILS = "you@example.com"

# Anthropic API key for the admin-only 'AI Analysis' tab
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY = "sk-ant-..."

# Secret token for the automated refresh webhook.
# A free cron service pings your app URL with this token to trigger the
# daily refresh/grade pipeline without needing a user to log in.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REFRESH_TOKEN = "your-random-secret-token"

# Optional: email the daily digest via Resend (https://resend.com — 3k free/mo)
# Sign up, grab an API key, optionally verify your domain (or use resend.dev shared sender)
RESEND_API_KEY = "re_..."
DIGEST_FROM = "digest@squeezetheline.com"  # or "onboarding@resend.dev" if you haven't verified a domain
DIGEST_RECIPIENTS = "you@example.com"       # comma-separate for multiple
